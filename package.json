{
  "name": "codeoid",
  "version": "0.1.3",
  "description": "Identity-first control plane for AI coding agents — multi-session, multi-frontend, with cross-session memory",
  "type": "module",
  "workspaces": ["packages/*"],
  "bin": {
    "codeoid": "./src/cli.ts"
  },
  "files": [
    "src",
    "!src/tests",
    "!src/**/*.test.ts",
    "web/dist",
    "!web/dist/**/*.map",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs/architecture.png"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saucam/codeoid.git"
  },
  "homepage": "https://github.com/saucam/codeoid#readme",
  "bugs": {
    "url": "https://github.com/saucam/codeoid/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai-agents",
    "coding-agent",
    "agent-identity",
    "zeroid",
    "tui",
    "bun",
    "mcp"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun --sourcemap",
    "build:web": "cd web && bun install --frozen-lockfile && bun run build",
    "dev": "bun --watch src/cli.ts",
    "lint": "biome check src/ packages/protocol/src/",
    "lint:fix": "biome check --write src/ packages/protocol/src/",
    "format": "biome format --write src/ packages/protocol/src/",
    "test": "bun test src/tests src/daemon packages/protocol/src",
    "test:coverage": "bun test src/tests src/daemon packages/protocol/src --coverage --coverage-reporter=lcov --reporter=junit --reporter-outfile=junit.xml",
    "test:web": "cd web && bun run test",
    "typecheck": "bun x tsc --noEmit && bun x tsc --noEmit -p packages/protocol",
    "prepublishOnly": "bun run build:web"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.175",
    "@codeoid/protocol": "^0.1.0",
    "@google/generative-ai": "^0.24.1",
    "@grammyjs/auto-retry": "^2.0.2",
    "@highflame/sdk": "^0.3.17",
    "@xenova/transformers": "^2.17.2",
    "commander": "^13.0.0",
    "grammy": "^1.35.0",
    "ink": "^7.0.1",
    "ink-text-input": "^6.0.0",
    "openai": "^6.45.0",
    "react": "^19.2.5",
    "react-devtools-core": "^7.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
