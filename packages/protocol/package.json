{
  "name": "@codeoid/protocol",
  "version": "0.2.0",
  "description": "Codeoid client↔daemon wire protocol — message/event types + permission scopes. Shared by the daemon, web UI, and mobile client.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saucam/codeoid.git",
    "directory": "packages/protocol"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schemas": {
      "types": "./src/schemas.ts",
      "default": "./src/schemas.ts"
    }
  },
  "sideEffects": false,
  "files": ["src", "!src/**/*.test.ts", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  }
}
